{
  "name": "flowlens",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @flowlens/web",
    "dev:extension": "npm run dev -w @flowlens/extension",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @flowlens/web",
    "build:extension": "npm run build -w @flowlens/extension",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @flowlens/web",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
