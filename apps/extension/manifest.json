{
  "manifest_version": 3,
  "name": "FlowLens",
  "version": "1.0.0",
  "description": "Record website journeys and turn them into editable visual workflows.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "tabs", "storage", "unlimitedStorage", "scripting"],
  "host_permissions": ["https://flowlens-bx6p.onrender.com/*"],
  "background": { "service_worker": "src/background/index.ts", "type": "module" },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "FlowLens",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://flowlens-bx6p.onrender.com/*"],
      "js": ["src/content/bridge.ts"],
      "run_at": "document_start"
    }
  ]
}
